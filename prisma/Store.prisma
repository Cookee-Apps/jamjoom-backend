model Store {
  id                        String    @id @default(uuid())
  userId                    String    @unique
  user                      Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                      String
  storeManager              String?
  contactNumber             String?
  location                  String?
  active                    Boolean   @default(true)
  storeImage                String?
  address                   String?
  placeName                 String?
  notificationContactNumber String?
  latitude                  Decimal?  @db.Decimal(10, 8)
  longitude                 Decimal?  @db.Decimal(11, 8)
  locationEmbedLink         String?
  serviceRadius             Int       @default(0)
  refNo                     Int       @default(autoincrement())
  deletedAt                 DateTime?

  createdAt DateTime @default(now())
  banners   Banner[]

  currentStoreUsers Users[] @relation("CurrentStoreUsers")

  walletTransactions WalletTransactions[]
  trollyScans        TrollyScans[]
  TrollyGift         TrollyGift[]

  @@index([userId])
  @@index([latitude, longitude])
}
