model TrollyConfig {
  id     String     @id @default(uuid())
  giftId String     @unique
  gift   TrollyGift @relation(fields: [giftId], references: [id])

  perDayGiftLimit Int

  remainingStock Int

  @@index([giftId])
}

model TrollyGift {
  id      String @id @default(uuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])
  nameEn  String
  nameMl  String
  imgEn   String
  imgMl   String
  tAndcEn String
  tAndcMl String

  active Boolean @default(true)

  config      TrollyConfig?
  TrollyScans TrollyScans[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}
