model Banner {
  id      String @id @default(uuid())
  titleEn String
  titleMl String
  imgEn   String
  imgMl   String
  linkEn  String
  linkMl  String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
